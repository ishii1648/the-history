{
  "nodeModulesDir": "none",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "deno.ns"]
  },
  "fmt": {
    "exclude": ["backlog/", "data/"]
  },
  "tasks": {
    "build": "deno run --allow-read --allow-write --allow-run scripts/build.ts",
    "build-data": "deno run --allow-net --allow-read --allow-write scripts/build-data.ts",
    "build-colors": "deno run --allow-read --allow-write scripts/build-colors.ts",
    "next-task": "deno run --allow-read scripts/next_task.ts",
    "serve": "deno run --allow-net --allow-read jsr:@std/http@^1/file-server dist",
    "test": "deno test",
    "test:watch": "deno test --watch"
  },
  "imports": {
    "@deck.gl/core": "npm:@deck.gl/core@^9.3.7",
    "@deck.gl/layers": "npm:@deck.gl/layers@^9.3.7",
    "@protomaps/basemaps": "npm:@protomaps/basemaps@^5.7.2",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/yaml": "jsr:@std/yaml@^1",
    "@turf/bbox-clip": "npm:@turf/bbox-clip@^7",
    "@turf/helpers": "npm:@turf/helpers@^7",
    "@turf/simplify": "npm:@turf/simplify@^7",
    "@turf/truncate": "npm:@turf/truncate@^7",
    "geojson": "npm:@types/geojson@^7946.0.16",
    "maplibre-gl": "npm:maplibre-gl@^4.7.1",
    "pmtiles": "npm:pmtiles@^3.2.1"
  }
}
