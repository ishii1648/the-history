{
  "nodeModulesDir": "none",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "deno.ns"]
  },
  "fmt": {
    "exclude": ["backlog/", "data/", "vendor/"]
  },
  "tasks": {
    "build": "deno run --allow-read --allow-write --allow-run scripts/build.ts",
    "build-data": "deno run --allow-net --allow-read --allow-write scripts/build-data.ts",
    "build-rivers": "deno run --allow-net --allow-read --allow-write scripts/build-rivers.ts",
    "build-cities": "deno run --allow-net --allow-read --allow-write scripts/build-cities.ts",
    "build-colors": "deno run --allow-read --allow-write scripts/build-colors.ts",
    "build-hre": "deno run --allow-net --allow-read --allow-write scripts/build-hre.ts",
    "extract-pmtiles": "deno run --allow-net=build-metadata.protomaps.dev --allow-run=pmtiles --allow-read scripts/extract-pmtiles.ts",
    "extract-dem": "deno run --allow-net=s3.amazonaws.com --allow-read --allow-write scripts/extract-dem.ts",
    "next-task": "deno run --allow-read scripts/next_task.ts",
    "next-tasks": "deno run --allow-read scripts/next_tasks.ts",
    "serve": "deno run --allow-net --allow-read jsr:@std/http@^1/file-server dist",
    "test": "deno test",
    "test:watch": "deno test --watch"
  },
  "imports": {
    "@deck.gl/core": "npm:@deck.gl/core@^9.3.7",
    "@deck.gl/extensions": "npm:@deck.gl/extensions@^9.3.7",
    "@deck.gl/layers": "npm:@deck.gl/layers@^9.3.7",
    "@deck.gl/mapbox": "npm:@deck.gl/mapbox@^9.3.7",
    "@mapbox/polylabel": "npm:@mapbox/polylabel@^1.0.2",
    "@protomaps/basemaps": "npm:@protomaps/basemaps@^5.7.2",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/csv": "jsr:@std/csv@^1",
    "@std/yaml": "jsr:@std/yaml@^1",
    "@turf/bbox-clip": "npm:@turf/bbox-clip@^7",
    "@turf/helpers": "npm:@turf/helpers@^7",
    "@turf/simplify": "npm:@turf/simplify@^7",
    "@turf/truncate": "npm:@turf/truncate@^7",
    "geojson": "npm:@types/geojson@^7946.0.16",
    "maplibre-gl": "npm:maplibre-gl@^4.7.1",
    "shapefile": "npm:shapefile@0.6.6",
    "pmtiles": "npm:pmtiles@^3.2.1"
  }
}
